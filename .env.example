# Which basemap tile source DeckLineLayerMap.jsx uses — see BASEMAP_SOURCES
# in src/js/Components/DeckLineLayerMap.jsx for the valid keys and what each
# one means (offline/commercial-safe vs. online/non-commercial).
#
# natural_earth      - offline, self-rendered, public-domain, commercial-safe
# carto_dark_online  - live tiles from CARTO's free tier, non-commercial only
ACTIVE_BASEMAP=natural_earth
